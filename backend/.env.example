PORT=3001
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_publishable_key_here
# Optional backend-only service role key. Do not use a Supabase personal access token here.
SUPABASE_SERVICE_ROLE_KEY=

# Required for real AI responses through your Supabase Edge Function
SUPABASE_AI_CHAT_URL=https://your-project.supabase.co/functions/v1/ai-chat
SUPABASE_AI_API_KEY=your_supabase_publishable_key_here
AI_PROVIDER=openrouter
AI_MODEL_ID=your_model_id
AI_TOKEN_SLOT_ID=your_token_slot_id

# Optional. If missing, the app uses a local deterministic embedding fallback.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

MAX_RETRIEVED_CHUNKS=5
MIN_RETRIEVAL_SCORE=0.05
RAG_FAST_MODE=false
AI_MAX_TOKENS=1024
AI_ATTEMPT_TIMEOUT_MS=10000
